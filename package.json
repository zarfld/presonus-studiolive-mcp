{
  "name": "presonus-studiolive-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server for PreSonus StudioLive mixers — provides AI-agent context for show preparation, soundcheck diagnostics, and routing validation",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "tsc --build",
    "build:watch": "tsc --build --watch",
    "clean": "pnpm -r exec rimraf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:hil": "cross-env HIL_PRESONUS=1 vitest run --config vitest.hil.config.ts",
    "test:coverage": "vitest run --coverage",
    "probe": "node packages/presonus-inspector/dist/cli/probe.js",
    "probe:dev": "tsx packages/presonus-inspector/src/cli/probe.ts",
    "mcp:server": "node packages/presonus-mcp-server/dist/index.js",
    "mcp:server:dev": "tsx packages/presonus-mcp-server/src/index.ts",
    "typecheck": "tsc --build --dry",
    "inventory": "tsx scripts/generate-capability-matrix.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "cross-env": "^7.0.3",
    "rimraf": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  }
}
